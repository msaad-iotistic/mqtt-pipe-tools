# MQTT Wormhole - Broker Configuration
# Copy this file to .env and fill in your broker details
# Command-line arguments override these values

# MQTT Broker Connection
MQTT_HOST=broker.example.com
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false
MQTT_INSECURE=false
MQTT_CA_CERTS=

# Encryption (optional but recommended for public brokers)
MQTT_ENCRYPTION_KEY=
MQTT_ENCRYPTION_SALT=
MQTT_ENCRYPTION_ITERATIONS=210000

# Transfer Settings
MQTT_QOS=1
MQTT_CHUNK_SIZE=65536
MQTT_COMPRESSION=deflate
